# Ark-playground Supabase (never commit .env)
SUPABASE_URL=https://deoyyzrzoacyjeozwvek.supabase.co

# Client-safe key (macOS app / future read paths)
SUPABASE_PUBLISHABLE_KEY=

# Daemon sync only — server secret (Dashboard → Settings → API)
# Accepts sb_secret_... (new) or legacy service_role JWT (eyJ...)
SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional workspace scope for multi-tenant sync
ARKHE_WORKSPACE_ID=ark-playground

# AI stack
ARKHE_APPLE_FOUNDATION_MODELS=1
ARKHE_AUTO_APPROVE=1
ARKHE_LOCAL_MODELS=1
OLLAMA_HOST=http://127.0.0.1:11434
ARKHE_OLLAMA_MODEL=qwen3:8b

# Cloud escalation (optional)
# ARKHE_PAID_CLOUD=1
# ARKHE_OPENAI_API_KEY=

# Attention Cortex (Autonomous Media / attn-big) — adapter envs (no keys required for curated fallbacks)
# ARKHE_ATTENTION_SCAN_INTERVAL_MS=14400000   # 4h default; 86400000 = daily
# ARKHE_ATTENTION_AUTONOMOUS=1                # (future) set 0 to disable auto scheduler
#
# Trends (real when keys set; curated fallback otherwise):
# YOUTUBE_API_KEY=          # YouTube Data API v3 search + videos.list
# YOUTUBE_TREND_QUERY=      # optional (default: "AI agents automation")
# X_BEARER_TOKEN=           # X API v2 tweets/search/recent
# X_TREND_QUERY=            # optional (default: "AI agents OR local automation lang:en -is:retweet")
# Or configure from macOS Settings → Attention Cortex / YouTube or / X (persists to ~/.arkhe/attention-config.json)
#
# Video generation (Kling + Runway create real tasks when keys set; Veo/Hailuo remain stubbed):
# KLING_API_KEY=            # POST api.klingai.com/v1/videos/text2video
# RUNWAY_API_KEY=           # POST api.dev.runwayml.com/v1/text_to_video
# GOOGLE_GENAI_API_KEY=     # or VEO_API_KEY for Veo (stub)
# HAILUO_API_KEY=           # or MINIMAX_API_KEY (stub)
#
# YouTube publish OAuth (refresh + channels.list; real videos.insert when video file present):
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=    # or save via Settings → Attention Cortex / YouTube
# YOUTUBE_REDIRECT_URI=     # only needed for initial OAuth consent flow
# ARKHE_YOUTUBE_UPLOAD_PATH=/path/to/video.mp4   # optional smoke-test override for resumable upload

