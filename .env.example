# Ark-playground Supabase (never commit .env)
SUPABASE_URL=https://deoyyzrzoacyjeozwvek.supabase.co

# Client-safe key (macOS app / future read paths)
SUPABASE_PUBLISHABLE_KEY=

# Daemon sync only — server secret (Dashboard → Settings → API)
# Accepts sb_secret_... (new) or legacy service_role JWT (eyJ...)
SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional workspace scope for multi-tenant sync
ARKHE_WORKSPACE_ID=ark-playground

# AI stack
ARKHE_APPLE_FOUNDATION_MODELS=1
ARKHE_AUTO_APPROVE=1
ARKHE_LOCAL_MODELS=1
OLLAMA_HOST=http://127.0.0.1:11434
ARKHE_OLLAMA_MODEL=qwen3:8b

# Cloud escalation (optional)
# ARKHE_PAID_CLOUD=1
# ARKHE_OPENAI_API_KEY=
