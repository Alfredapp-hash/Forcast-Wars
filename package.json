{
  "name": "arkhe-agentos",
  "version": "0.1.0",
  "private": true,
  "description": "Forecast Wars — public AI debate arena, powered by Arkhe AgentOS",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@arkhe/forecast-wars",
    "dev:daemon": "turbo run dev --filter=@arkhe/local-daemon",
    "dev:hermes": "turbo run dev --filter=@arkhe/hermes",
    "dev:forecast-wars": "turbo run dev --filter=@arkhe/forecast-wars",
    "build:forecast-wars": "turbo run build --filter=@arkhe/forecast-wars",
    "start:forecast-wars": "bash infra/dev/start-forecast-wars.sh",
    "sync:forecast-wars-env": "bash scripts/sync-forecast-wars-env.sh",
    "smoke:forecast-wars": "node scripts/smoke-forecast-wars.mjs",
    "smoke:daemon": "node scripts/smoke-daemon.mjs",
    "smoke:hermes": "node scripts/smoke-hermes.mjs",
    "check:local": "bash scripts/check-local.sh",
    "start:alpha": "bash infra/dev/start-alpha.sh",
    "bundle:daemon": "bash infra/dev/bundle-daemon.sh",
    "package:app": "bash infra/dev/package-app.sh",
    "qa:alpha": "node scripts/qa-alpha.mjs",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22"
  }
}
