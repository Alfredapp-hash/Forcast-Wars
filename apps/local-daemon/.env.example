# ─────────────────────────────────────────────────────────────────────────────
# Arkhe local-daemon — environment variables
# Copy to .env and fill in real values before running `pnpm dev:daemon`.
# ─────────────────────────────────────────────────────────────────────────────

# IPC / WebSocket
ARKHE_WS_PORT=9470
ARKHE_SOCKET=~/.arkhe/daemon.sock
ARKHE_DATA_DIR=~/.arkhe
ARKHE_MEMORY_PATH=~/.arkhe/events.json
ARKHE_ARTIFACTS_DIR=~/.arkhe/artifacts
ARKHE_MEMORIES_PATH=~/.arkhe/MEMORIES.md

# NATS JetStream (optional — daemon falls back to in-process bus if unavailable)
NATS_URL=nats://127.0.0.1:4222

# Hermes routing service (optional — approvals forwarded when available)
HERMES_URL=http://127.0.0.1:4000

# Supabase (optional — enables cloud resident + memory sync)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# Model routing
# Layer 1 — Apple Foundation Models (macOS 26+)
ARKHE_APPLE_FOUNDATION_MODELS=0

# Layer 2 — Ollama local (default: http://127.0.0.1:11434)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Layer 3 — Paid cloud (set to 1 to enable; requires API keys below)
ARKHE_PAID_CLOUD_ENABLED=0
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Approvals
# Set to 1 to auto-approve all agent actions (dev/test only)
ARKHE_AUTO_APPROVE=0

# Attention Cortex
YOUTUBE_API_KEY=
YOUTUBE_TREND_QUERY=AI automation productivity
YOUTUBE_OAUTH_REFRESH_TOKEN=
X_BEARER_TOKEN=
X_TREND_QUERY=AI agents productivity

# Autonomous scan intervals (milliseconds)
ARKHE_ATTENTION_SCAN_INTERVAL_MS=14400000
ARKHE_DOCUMENTARY_SCAN_INTERVAL_MS=86400000
