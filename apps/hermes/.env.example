# ─────────────────────────────────────────────────────────────────────────────
# Hermes — environment variables
# Copy this file to .env and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# HTTP server
# The daemon connects to Hermes at http://127.0.0.1:HERMES_PORT (set HERMES_URL in daemon .env)
HERMES_HOST=0.0.0.0
HERMES_PORT=4000

# NATS JetStream (shared with local-daemon)
NATS_URL=nats://127.0.0.1:4222

# Supabase (service-role key required for Hermes table writes)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# Redis (optional — used by BullMQ workers in Phase 5)
REDIS_URL=redis://127.0.0.1:6379

# Logging
LOG_LEVEL=info
